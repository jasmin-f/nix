{
	// Typst Anki workspace snippets. Each snippet is defined under a snippet name and has a scope, prefix, body and 
	// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope 
	// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is 
	// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: 
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. 
	// Placeholders with the same ids are connected.

	"#add-note-normal": {
		"scope": "typst,typ",
		"prefix": "#add-note-normal",
		"body": [
			"#add-note-normal(",
			"	\"$1\", // question",
			"	\"$2\", // answer",
			"	\"$3\", // more info",
			"	format: ta.template-note",
			")",
		],
		"description": "template to create anki typst card",
	},
	"#add-note-eintippen": {
		"scope": "typst,typ",
		"prefix": "#add-note-eintippen",
		"body": [
			"#add-note-eintippen(",
			"	\"$1\", // question",
			"	\"$2\", // answer",
			"	\"$3\", // more info",
			"	format: ta.template-note",
			")",
		],
		"description": "template to create anki typst card",
	},
	"#add-note-multipleChoice": {
		"scope": "typst,typ",
		"prefix": "#add-note-multipleChoice",
		"body": [
			"#add-note-multipleChoice(",
			"	\"$1\", // question",
			"	\"$2\", // A",
			"	\"$3\", // B",
			"	\"$4\", // C",
			"	\"$5\", // D",
			"	\"$6\", // E",
			"	\"$7\", // F",
			"	\"$8\", // correct answers, example "A" or multiple "ABC"",
			"	format: ta.template-note",
			")",
		],
		"description": "template to create anki typst card",
	},
	"#add-note-lueckentext": {
		"scope": "typst,typ",
		"prefix": "#add-note-lueckentext",
		"body": [
			"#add-note-lueckentext(",
			"	\"$1\", // Lueckentext, lorem ipsum {{c1::hidden}} ...",
			"	\"$2\", // Hint",
			"	\"$3\", // Type",
			"	\"$4\", // Extra",
			"	\"$5\", // Cloze99",
			"	format: ta.template-note",
			")",
		],
		"description": "template to create anki typst card",
	},

}